---
import { getEmDashCollection, getEntryTerms } from "emdash";
import { Image } from "emdash/ui";
import Base from "../layouts/Base.astro";
import PostCard from "../components/PostCard.astro";
import { getReadingTime } from "../utils/reading-time";

const { entries: posts, cacheHint } = await getEmDashCollection("posts");
Astro.cache.set(cacheHint);

const sortedPosts = posts.toSorted((a, b) => {
	const dateA = a.data.publishedAt?.getTime() ?? 0;
	const dateB = b.data.publishedAt?.getTime() ?? 0;
	return dateB - dateA;
});

const recentPosts = sortedPosts.slice(0, 6);

const postsWithTags = await Promise.all(
	recentPosts.map(async (post) => {
		const tags = await getEntryTerms("posts", post.data.id, "tag");
		return { post, tags: tags.map((t) => ({ slug: t.slug, label: t.label })), bylines: post.data.bylines ?? [] };
	})
);
---

<Base title="Managed IT Services Cleveland" description="Acendex provides managed IT services, private cloud computing, cybersecurity, and disaster recovery for businesses in Cleveland, Ohio.">
	<!-- Hero Section -->
	<section class="acx-hero">
		<div class="acx-hero-overlay"></div>
		<div class="acx-container acx-hero-content">
			<h1>Smart IT Solutions for<br/>Growing Businesses</h1>
			<p>Managed IT Services, Private Cloud, Cybersecurity &amp; Disaster Recovery</p>
			<div class="acx-hero-buttons">
				<a href="/pages/contact" class="acx-btn acx-btn-primary">Get a Free Consultation</a>
				<a href="/pages/services" class="acx-btn acx-btn-outline">Our Services</a>
			</div>
		</div>
	</section>

	<!-- Services Overview -->
	<section class="acx-section">
		<div class="acx-container acx-text-center">
			<h2 class="acx-section-title">Our IT Services</h2>
			<p class="acx-section-subtitle">Smart design and nimble trouble-shooting mean your IT problems get solved more quickly.</p>
			<div class="acx-services-grid">
				<a href="/pages/managed-services" class="acx-service-card">
					<div class="acx-service-icon">🖥️</div>
					<h3>Managed IT Services</h3>
					<p>Proactive monitoring, maintenance, and support for your entire IT infrastructure.</p>
				</a>
				<a href="/pages/private-cloud-computing" class="acx-service-card">
					<div class="acx-service-icon">☁️</div>
					<h3>Private Cloud</h3>
					<p>Secure, scalable cloud solutions tailored to your business needs.</p>
				</a>
				<a href="/pages/cybersecurity-services-cleveland" class="acx-service-card">
					<div class="acx-service-icon">🔒</div>
					<h3>Cybersecurity</h3>
					<p>Protect your business from threats with comprehensive security solutions.</p>
				</a>
				<a href="/pages/acendexassure-disaster-recovery" class="acx-service-card">
					<div class="acx-service-icon">🔄</div>
					<h3>Disaster Recovery</h3>
					<p>Business continuity planning and rapid recovery when disaster strikes.</p>
				</a>
			</div>
		</div>
	</section>

	<!-- CTA Section -->
	<section class="acx-cta-section">
		<div class="acx-container acx-text-center">
			<h2>Ready to Transform Your IT?</h2>
			<p>Contact us today for a free consultation and discover how Acendex can help your business thrive.</p>
			<a href="/pages/contact" class="acx-btn acx-btn-primary">Contact Us Today</a>
		</div>
	</section>

	<!-- Latest Blog Posts -->
	{postsWithTags.length > 0 && (
		<section class="acx-section">
			<div class="acx-container">
				<div class="acx-text-center" style="margin-bottom: 40px;">
					<h2 class="acx-section-title">Latest from Our Blog</h2>
				</div>
				<div class="posts-grid">
					{postsWithTags.map(({ post, tags, bylines }) => (
						<PostCard
							title={post.data.title ?? "Untitled"}
							excerpt={post.data.excerpt}
							featuredImage={post.data.featured_image}
							href={`/posts/${post.id}`}
							date={post.data.publishedAt ?? undefined}
							readingTime={getReadingTime(post.data.content)}
							tags={tags}
							bylines={bylines}
						/>
					))}
				</div>
				{sortedPosts.length > 6 && (
					<div class="acx-text-center" style="margin-top: 40px;">
						<a href="/posts" class="acx-btn acx-btn-outline">View All Posts</a>
					</div>
				)}
			</div>
		</section>
	)}
</Base>

<style>
	/* Hero */
	.acx-hero {
		position: relative;
		background: linear-gradient(140deg, var(--acx-blue) 0%, var(--acx-purple) 60%, var(--acx-pink) 100%);
		padding: 120px 0 100px;
		text-align: center;
		color: white;
		overflow: hidden;
	}
	.acx-hero-overlay {
		position: absolute; inset: 0;
		background: url('/images/acendex-logo.png') no-repeat center center;
		background-size: 300px;
		opacity: 0.05;
	}
	.acx-hero-content { position: relative; z-index: 1; }
	.acx-hero h1 { font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 700; margin-bottom: 20px; color: white; }
	.acx-hero p { font-size: 1.25rem; opacity: 0.9; margin-bottom: 30px; max-width: 600px; margin-left: auto; margin-right: auto; }
	.acx-hero-buttons { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }

	/* Buttons */
	.acx-btn {
		display: inline-block; padding: 14px 32px; border-radius: 4px;
		font-weight: 600; font-size: 0.95rem; text-decoration: none;
		transition: all 0.3s ease; text-transform: uppercase; letter-spacing: 1px;
	}
	.acx-btn-primary { background: var(--acx-orange); color: white; }
	.acx-btn-primary:hover { background: var(--acx-orange-dark); color: white; }
	.acx-btn-outline { background: transparent; color: white; border: 2px solid white; }
	.acx-btn-outline:hover { background: white; color: var(--acx-blue); }

	/* Section titles */
	.acx-section-title { font-size: 2rem; color: var(--acx-blue); margin-bottom: 12px; }
	.acx-section-subtitle { color: var(--color-text-secondary); font-size: 1.1rem; max-width: 600px; margin: 0 auto 40px; }

	/* Services grid */
	.acx-services-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 30px; margin-top: 20px; }
	.acx-service-card {
		background: white; border: 1px solid var(--color-border); border-radius: 8px;
		padding: 40px 24px; text-align: center; text-decoration: none; color: inherit;
		transition: all 0.3s ease;
	}
	.acx-service-card:hover { transform: translateY(-4px); box-shadow: 0 12px 30px rgba(0,0,0,0.1); border-color: var(--acx-blue); }
	.acx-service-icon { font-size: 2.5rem; margin-bottom: 16px; }
	.acx-service-card h3 { font-size: 1.15rem; color: var(--acx-blue); margin-bottom: 10px; }
	.acx-service-card p { font-size: 0.9rem; color: var(--color-text-secondary); line-height: 1.6; }

	/* CTA */
	.acx-cta-section {
		background: linear-gradient(140deg, var(--acx-blue) 0%, var(--acx-purple) 100%);
		padding: 80px 0; color: white;
	}
	.acx-cta-section h2 { font-size: 2rem; margin-bottom: 16px; color: white; }
	.acx-cta-section p { font-size: 1.1rem; opacity: 0.9; margin-bottom: 30px; max-width: 500px; margin-left: auto; margin-right: auto; }

	/* Blog grid */
	.posts-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px; }

	@media (max-width: 1024px) {
		.acx-services-grid { grid-template-columns: repeat(2, 1fr); }
		.posts-grid { grid-template-columns: repeat(2, 1fr); }
	}
	@media (max-width: 768px) {
		.acx-services-grid, .posts-grid { grid-template-columns: 1fr; }
		.acx-hero { padding: 80px 0 60px; }
	}
</style>
