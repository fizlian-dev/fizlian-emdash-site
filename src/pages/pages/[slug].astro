---
import { getEmDashEntry } from "emdash";
import { PortableText } from "emdash/ui";
import Base from "../../layouts/Base.astro";

const { slug } = Astro.params;

if (!slug) {
	return Astro.redirect("/404");
}

const { entry: page, cacheHint } = await getEmDashEntry("pages", slug);

if (!page) {
	return Astro.redirect("/404");
}

Astro.cache.set(cacheHint);
---

<Base
	title={page.data.title}
	content={{ collection: "pages", id: page.data.id, slug }}
>
	<div class="acx-page-header">
		<div class="acx-container">
			<h1 {...page.edit.title}>{page.data.title}</h1>
		</div>
	</div>

	<article class="page-article">
		<div class="page-content">
			<PortableText value={page.data.content} />
		</div>
	</article>
</Base>

<style>
	.page-article {
		max-width: var(--content-width);
		margin: 0 auto;
		padding: 60px 20px;
	}
	.page-content :global(p) { margin-bottom: 1.5em; line-height: 1.8; }
	.page-content :global(h2) { font-size: 1.75rem; margin-top: 2em; margin-bottom: 0.75em; color: var(--acx-blue); }
	.page-content :global(h3) { font-size: 1.35rem; margin-top: 1.75em; margin-bottom: 0.5em; }
	.page-content :global(ul), .page-content :global(ol) { margin-bottom: 1.5em; padding-left: 1.5em; }
	.page-content :global(li) { margin-bottom: 0.5em; }
	.page-content :global(blockquote) { margin: 1.5em 0; padding-left: 1.5rem; border-left: 4px solid var(--acx-blue); color: var(--color-text-secondary); }
	.page-content :global(img) { margin: 2em 0; border-radius: 8px; }
	.page-content :global(a) { color: var(--acx-blue); text-decoration: underline; }
</style>
